FROM ubuntu:22.04

# Evitar prompts interactivos durante la instalación
ENV DEBIAN_FRONTEND=noninteractive

# Instalar Python y dependencias del sistema
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    lm-sensors \
    iproute2 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/agent

# Instalar dependencias Python del agente
RUN pip3 install --no-cache-dir psutil requests

# Copiar el agente
COPY agent.py /opt/agent/agent.py

# Variables de entorno configurables
ENV MONITOR_SERVER_URL=http://web:5000/metricas
ENV AGENT_INTERVAL=60
ENV PYTHONUNBUFFERED=1

CMD ["python3", "/opt/agent/agent.py"]
